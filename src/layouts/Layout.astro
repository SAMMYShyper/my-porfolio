---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Computer Science portfolio for Samuel Gonzalez" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<nav>
			<div class="nav-container">
				<a href="/" class="logo" aria-label="Samuel Gonzalez home">
					<span class="mark">SG</span>
					<span>Samuel Gonzalez</span>
				</a>
				<div class="nav-links" aria-label="Profile links">
					<a href="https://github.com/SammysHyper" target="_blank" rel="noopener noreferrer">github</a>
					<a href="https://linkedin.com/in/samuelgonzalezusf/" target="_blank" rel="noopener noreferrer">linkedin</a>
					<a href="mailto:samuelgonzalez@usf.edu">email</a>
				</div>
			</div>
		</nav>

		<main>
			<slot />
		</main>

		<footer>
			<p>&copy; {new Date().getFullYear()} Samuel Gonzalez. Built with Astro and React.</p>
		</footer>
	</body>
</html>

<style is:global>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	:root {
		--ink: #0d0f0e;
		--ink-2: #151816;
		--ink-3: #1f231f;
		--paper: #f2f3eb;
		--soft: #cdd3ca;
		--muted: #92998f;
		--dim: #6f786e;
		--accent: #67e8dc;
		--accent-2: #c4f36a;
		--accent-3: #ffb86b;
		--line: rgba(242, 243, 235, 0.13);
		--line-strong: rgba(242, 243, 235, 0.24);
		--shadow: 0 22px 60px rgba(0, 0, 0, 0.36);
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
		line-height: 1.6;
		color: var(--soft);
		background:
			linear-gradient(180deg, rgba(103, 232, 220, 0.04), transparent 28rem),
			var(--ink);
		text-rendering: optimizeLegibility;
	}

	nav {
		position: sticky;
		top: 0;
		z-index: 100;
		backdrop-filter: blur(18px);
		background: rgba(13, 15, 14, 0.72);
		border-bottom: 1px solid var(--line);
	}

	.nav-container {
		max-width: 1080px;
		margin: 0 auto;
		padding: 1rem 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
	}

	.logo {
		color: var(--paper);
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		transition: opacity 0.2s ease;
	}

	.mark {
		display: grid;
		width: 2.05rem;
		height: 2.05rem;
		place-items: center;
		border: 1px solid var(--line-strong);
		border-radius: 50%;
		color: var(--accent);
		font-size: 0.72rem;
		letter-spacing: 0.04em;
	}

	.logo:hover {
		opacity: 0.72;
	}

	.nav-links {
		display: flex;
		gap: 0.85rem;
		align-items: center;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.nav-links a {
		color: var(--muted);
		text-decoration: none;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: lowercase;
		transition: color 0.2s;
	}

	.nav-links a:hover {
		color: var(--paper);
	}

	main {
		min-height: calc(100vh - 140px);
	}

	footer {
		background: #080908;
		padding: 2rem 1.5rem;
		text-align: center;
		border-top: 1px solid var(--line);
	}

	footer p {
		color: var(--dim);
		font-size: 0.92rem;
	}

	section {
		max-width: 1080px;
		margin: 0 auto;
		padding: 5.5rem 1.5rem;
	}

	h1 {
		font-size: clamp(3rem, 8vw, 6.75rem);
		line-height: 0.94;
		margin-bottom: 1rem;
		color: var(--paper);
		letter-spacing: 0;
	}

	h2 {
		font-size: clamp(1.75rem, 3vw, 2.7rem);
		line-height: 1.05;
		margin-bottom: 2rem;
		color: var(--paper);
		letter-spacing: 0;
	}

	h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		color: var(--paper);
	}

	p {
		color: var(--muted);
		font-size: 1rem;
	}

	@media (max-width: 768px) {
		.nav-container {
			align-items: center;
			flex-direction: row;
		}

		.nav-links {
			gap: 0.55rem;
		}

		.logo span:last-child {
			display: none;
		}

		h2 {
			font-size: 1.8rem;
		}

		section {
			padding: 4rem 1.25rem;
		}
	}
</style>
