---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Computer Science portfolio for Samuel Gonzalez" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<nav>
			<div class="nav-container">
				<a href="/" class="logo">Samuel Gonzalez</a>
				<ul class="nav-links">
					<li><a href="#about">About</a></li>
					<li><a href="#projects">Projects</a></li>
					<li><a href="#skills">Skills</a></li>
					<li><a href="#contact">Connect</a></li>
				</ul>
			</div>
		</nav>

		<main>
			<slot />
		</main>

		<footer>
			<p>&copy; {new Date().getFullYear()} Built by Sam, with Astro & React.</p>
		</footer>
	</body>
</html>

<style is:global>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	:root {
		--ink: #0a0a0a;
		--text: #18181b;
		--text-light: #666666;
		--muted: #8a8a8a;
		--bg: #ffffff;
		--bg-secondary: #f7f7f7;
		--border: #dedede;
		--border-strong: #b8b8b8;
		--shadow: 0 18px 45px rgba(0, 0, 0, 0.08);
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
		line-height: 1.6;
		color: var(--text);
		background: var(--bg);
		text-rendering: optimizeLegibility;
	}

	nav {
		position: sticky;
		top: 0;
		z-index: 100;
		backdrop-filter: blur(10px);
		background: rgba(255, 255, 255, 0.86);
		border-bottom: 1px solid rgba(222, 222, 222, 0.75);
	}

	.nav-container {
		max-width: 1080px;
		margin: 0 auto;
		padding: 1rem 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
	}

	.logo {
		color: var(--ink);
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		text-decoration: none;
		transition: opacity 0.2s ease;
	}

	.logo:hover {
		opacity: 0.72;
	}

	.nav-links {
		display: flex;
		gap: 1.25rem;
		list-style: none;
		align-items: center;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.nav-links a {
		color: var(--text-light);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 600;
		transition: color 0.2s;
	}

	.nav-links a:hover {
		color: var(--ink);
	}

	main {
		min-height: calc(100vh - 140px);
	}

	footer {
		background: var(--ink);
		padding: 2rem 1.5rem;
		text-align: center;
		border-top: 1px solid var(--ink);
	}

	footer p {
		color: #d4d4d4;
		font-size: 0.92rem;
	}

	section {
		max-width: 1080px;
		margin: 0 auto;
		padding: 5.5rem 1.5rem;
	}

	h1 {
		font-size: clamp(3rem, 8vw, 6.75rem);
		line-height: 0.94;
		margin-bottom: 1rem;
		color: var(--ink);
		letter-spacing: 0;
	}

	h2 {
		font-size: clamp(1.75rem, 3vw, 2.7rem);
		line-height: 1.05;
		margin-bottom: 2rem;
		color: var(--ink);
		letter-spacing: 0;
	}

	h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		color: var(--text);
	}

	p {
		color: var(--text-light);
		font-size: 1rem;
	}

	@media (max-width: 768px) {
		.nav-container {
			align-items: flex-start;
			flex-direction: column;
		}

		.nav-links {
			gap: 0.75rem;
		}

		h2 {
			font-size: 1.8rem;
		}

		section {
			padding: 4rem 1.25rem;
		}
	}
</style>
