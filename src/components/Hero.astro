---
// Hero.astro - Static component for the hero section
const pixels = Array.from({ length: 48 }, (_, index) => ({
	alpha: 0.16 + (index % 6) * 0.1,
	glow: 14 + (index % 8) * 5
}));
---

<section id="hero">
	<div class="hero-inner">
		<div class="hero-content">
			<p class="eyebrow">CS @ USF / Enterprise Engineering</p>
			<h1>Samuel Gonzalez</h1>
			<p class="title">I build practical systems with a competitive edge.</p>
			<p class="description">
				Computer science student, incoming Morgan Stanley tech analyst, GitHub enterprise support engineering intern,
				and collegiate esports player.
			</p>
			<div class="hero-meta" aria-label="Quick profile">
				<span>Python</span>
				<span>C/C++</span>
				<span>GitHub Copilot</span>
				<span>Spanish fluent</span>
			</div>
		</div>

		<div class="signal-board" aria-hidden="true">
			<div class="spiral"></div>
			<div class="portrait-slot">
				<span>SG</span>
			</div>
			<div class="pixel-field">
				{pixels.map((pixel) => <span style={`--alpha: ${pixel.alpha}; --glow: ${pixel.glow}%`}></span>)}
			</div>
			<div class="signal-caption">
				<span>build</span>
				<span>play</span>
				<span>ship</span>
			</div>
		</div>
	</div>
</section>

<style>
	#hero {
		max-width: 1120px;
		width: 100%;
		min-height: calc(100vh - 68px);
		display: grid;
		align-items: center;
		color: var(--paper);
		text-align: left;
		padding-top: 5rem;
		padding-bottom: 5rem;
		position: relative;
		overflow: hidden;
	}

	.hero-inner {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.75fr);
		gap: clamp(2.5rem, 7vw, 5rem);
		align-items: center;
	}

	.hero-content {
		max-width: 700px;
		position: relative;
		z-index: 1;
	}

	.eyebrow {
		color: var(--accent);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		margin-bottom: 1.25rem;
		text-transform: uppercase;
	}

	#hero h1 {
		font-size: clamp(3.2rem, 9vw, 7rem);
		line-height: 0.88;
		margin-bottom: 1.45rem;
		max-width: 7.6ch;
	}

	.title {
		font-size: clamp(1.2rem, 2.5vw, 1.8rem);
		line-height: 1.22;
		margin-bottom: 1rem;
		color: var(--paper);
		font-weight: 600;
	}

	.description {
		font-size: 1.05rem;
		line-height: 1.7;
		max-width: 41rem;
		color: var(--soft);
	}

	.hero-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-top: 1.8rem;
	}

	.hero-meta span {
		border: 1px solid var(--line);
		border-radius: 999px;
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 700;
		padding: 0.42rem 0.7rem;
	}

	.signal-board {
		aspect-ratio: 0.86;
		min-height: 460px;
		position: relative;
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(180deg, rgba(242, 243, 235, 0.05), rgba(242, 243, 235, 0.01)),
			repeating-linear-gradient(90deg, transparent 0 31px, rgba(242, 243, 235, 0.035) 32px),
			repeating-linear-gradient(0deg, transparent 0 31px, rgba(242, 243, 235, 0.035) 32px);
		box-shadow: var(--shadow);
		overflow: hidden;
	}

	.signal-board::before,
	.signal-board::after {
		content: "";
		position: absolute;
		inset: 1.1rem;
		border: 1px solid rgba(103, 232, 220, 0.16);
		border-radius: 50%;
		transform: scaleX(0.72);
	}

	.signal-board::after {
		inset: 2.8rem;
		border-color: rgba(196, 243, 106, 0.13);
		transform: scaleX(0.54) rotate(18deg);
	}

	.spiral {
		position: absolute;
		top: 3rem;
		left: 50%;
		width: 11rem;
		height: 11rem;
		border: 1px solid rgba(242, 243, 235, 0.7);
		border-left-color: transparent;
		border-radius: 50%;
		transform: translateX(-50%) rotate(18deg);
	}

	.spiral::before,
	.spiral::after {
		content: "";
		position: absolute;
		border: 1px solid rgba(242, 243, 235, 0.6);
		border-left-color: transparent;
		border-radius: 50%;
	}

	.spiral::before {
		inset: 1.6rem;
	}

	.spiral::after {
		inset: 3.1rem;
	}

	.portrait-slot {
		position: absolute;
		left: 50%;
		top: 45%;
		display: grid;
		width: min(52%, 210px);
		aspect-ratio: 1;
		place-items: center;
		border: 1px solid var(--line-strong);
		border-radius: 50%;
		background:
			linear-gradient(135deg, rgba(103, 232, 220, 0.18), rgba(255, 184, 107, 0.12)),
			var(--ink-2);
		transform: translate(-50%, -50%);
	}

	.portrait-slot span {
		color: var(--paper);
		font-size: clamp(2.8rem, 8vw, 5.7rem);
		font-weight: 900;
		letter-spacing: 0;
	}

	.pixel-field {
		position: absolute;
		inset: auto 1.5rem 3rem 1.5rem;
		display: grid;
		grid-template-columns: repeat(12, 1fr);
		gap: 0.45rem;
		opacity: 0.88;
	}

	.pixel-field span {
		aspect-ratio: 1;
		background: color-mix(in srgb, var(--accent) var(--glow), transparent);
		opacity: var(--alpha);
	}

	.signal-caption {
		position: absolute;
		right: 1.2rem;
		top: 1.1rem;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		color: var(--dim);
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.18em;
		text-align: right;
		text-transform: uppercase;
	}

	@media (max-width: 768px) {
		#hero {
			min-height: auto;
		}

		.hero-inner {
			grid-template-columns: 1fr;
		}

		.signal-board {
			min-height: 360px;
			order: -1;
		}
	}
</style>
