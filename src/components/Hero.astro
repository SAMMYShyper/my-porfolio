---
// Hero.astro - Static component for the hero section
---

<section id="hero">
	<div class="hero-content">
		<p class="eyebrow">Portfolio</p>
		<h1>Samuel Gonzalez</h1>
		<p class="title">Computer Science Undergraduate</p>
		<p class="description">University of South Florida</p>
	</div>
</section>

<style>
	#hero {
		max-width: none;
		width: 100%;
		margin: 0;
		min-height: 82vh;
		display: flex;
		align-items: center;
		justify-content: flex-start;
		background: #0a0a0a;
		color: white;
		text-align: left;
		padding: 6rem max(1.5rem, calc((100vw - 1080px) / 2));
		position: relative;
		overflow: hidden;
	}

	#hero::after {
		content: "";
		position: absolute;
		inset: auto -10vw -24vh auto;
		width: 58vw;
		height: 58vw;
		background: radial-gradient(circle, rgba(255, 255, 255, 0.12), transparent 62%);
		pointer-events: none;
	}

	.hero-content {
		max-width: 760px;
		position: relative;
		z-index: 1;
	}

	.eyebrow {
		color: rgba(255, 255, 255, 0.62);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		margin-bottom: 1.25rem;
		text-transform: uppercase;
	}

	#hero h1 {
		font-size: clamp(2.5rem, 5vw, 4.5rem);
		line-height: 1;
		margin-bottom: 1.25rem;
		color: white;
	}

	.title {
		font-size: clamp(1.15rem, 2.3vw, 1.55rem);
		margin-bottom: 0.35rem;
		color: rgba(255, 255, 255, 0.88);
		font-weight: 600;
	}

	.description {
		font-size: 1rem;
		margin-bottom: 2.5rem;
		color: rgba(255, 255, 255, 0.62);
	}

	@media (max-width: 768px) {
		#hero {
			min-height: 74vh;
		}

		.description {
			font-size: 1rem;
		}
	}
</style>
