---
// About.astro - Static component for the about section
---

<section id="about">
	<div class="about-content">
		<h2>About</h2>
		<p class="intro">
			Proficient in C++, C, Python<br>Previous GitHub Intern</bre>
		<div class="coursework">
			<h3>Coursework</h3>
			<p>
				Artificial Intelligence • Data Structures • Discrete Structures • Computer Organization • Digital Logic & Design • Program Design • Programming Concepts
			</p>
		</div>
		<div class="tools">
			<h3>Tools & Languages</h3>
			<p>
				C++ • C • Python • Pandas • NumPy • Scikit-learn • Matplotlib • Verilog • RISC-V
			</p>
		</div>
	</div>
</section>

<style>
	#about {
		background: #ffffff;
	}

	.about-content {
		max-width: 640px;
	}

	#about h2 {
		font-size: 2.5rem;
		margin-bottom: 2rem;
		color: #111111;
	}

	.intro {
		font-size: 1.05rem;
		line-height: 1.8;
		color: #4b5563;
		margin-bottom: 3rem;
	}

	.coursework {
		margin-top: 3rem;
	}

	.coursework h3 {
		font-size: 0.95rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: #6b7280;
		margin-bottom: 0.8rem;
		font-weight: 600;
	}

	.coursework p {
		font-size: 1rem;
		line-height: 1.7;
		color: #4b5563;
	}

	.tools {
		margin-top: 3rem;
	}

	.tools h3 {
		font-size: 0.95rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: #6b7280;
		margin-bottom: 0.8rem;
		font-weight: 600;
	}

	.tools p {
		font-size: 1rem;
		line-height: 1.7;
		color: #4b5563;
	}

	@media (max-width: 768px) {
		#about h2 {
			font-size: 1.8rem;
		}

		.intro {
			font-size: 1rem;
		}
	}
</style>
