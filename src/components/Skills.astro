---
// Skills.astro
const technicalGroups = [
	{
		title: "Languages",
		skills: ["C++", "C", "Python", "RISC-V", "Verilog"]
	},
	{
		title: "Tools",
		skills: ["GitHub", "GitHub Copilot", "Git/Unix/Linux Shell", "Pandas", "NumPy", "scikit-learn", "matplotlib"]
	}
];

const coursework = ["Data Structures", "Artificial Intelligence", "Discrete Structures", "Computer Logic & Design", "Program Design", "Programming Concepts"];
---

<section id="skills">
	<h2>Skills & Concepts</h2>
	<div class="skills-grid">
		<div class="skill-category technical-skills">
			{technicalGroups.map(group => (
				<div class="skill-group">
					<h3>{group.title}</h3>
					<div class="skill-tags">
						{group.skills.map(skill => (
							<span class="skill-tag">{skill}</span>
						))}
					</div>
				</div>
			))}
		</div>

		<div class="skill-category">
			<h3>Coursework</h3>
			<div class="skill-tags">
				{coursework.map(skill => (
					<span class="skill-tag">{skill}</span>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	#skills {
		background: #ffffff;
	}

	.skills-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.9fr);
		gap: 1rem;
	}

	.skill-category {
		background: var(--bg-secondary);
		padding: 1.5rem;
		border-radius: 8px;
		border: 1px solid var(--border);
	}

	.skill-group + .skill-group {
		border-top: 1px solid var(--border);
		margin-top: 1.5rem;
		padding-top: 1.5rem;
	}

	.skill-category h3 {
		color: #000000;
		margin-bottom: 1.5rem;
		font-size: 1.05rem;
		font-weight: 700;
	}

	.skill-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.skill-tag {
		background: white;
		color: var(--text);
		padding: 0.45rem 0.75rem;
		border-radius: 6px;
		font-size: 0.9rem;
		font-weight: 500;
		border: 1px solid var(--border);
		white-space: nowrap;
	}

	@media (max-width: 768px) {
		.skills-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
